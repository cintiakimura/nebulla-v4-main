# Server (optional; use if 3000 / 24678 are already in use)
# PORT=3001
# VITE_HMR_PORT=24679
# DISABLE_HMR=true

# --- Render (production) ---
# DATABASE_URL=postgresql://user:pass@host:5432/dbname   # from Render PostgreSQL → Connect → **External** URL (full host must resolve; e.g. …amazonaws.com or …postgres.render.com)
# If you see `getaddrinfo ENOTFOUND` or init errors: the DB may be deleted, the URL truncated, or only the internal hostname copied — paste the full External URL again, or remove DATABASE_URL for local dev without sign-in.
# DATABASE_SSL=   # omit or true for managed TLS; set "false" only for local Postgres without SSL
# SESSION_SECRET=   # strong random string (JWT signing + cookies)
# Optional: dedicated 32+ char secret for AES-256-GCM encryption of per-user Grok key overrides in PostgreSQL (defaults to deriving from SESSION_SECRET in dev).
# NEBULA_SECRETS_ENCRYPTION_KEY=
# Canonical public origin (no trailing slash). In production NODE_ENV=production this drives GitHub OAuth redirect_uri.
# Example custom domain:  PUBLIC_SITE_URL=https://nebula.dev
# Example Render URL:     PUBLIC_SITE_URL=https://your-service.onrender.com
# PUBLIC_SITE_URL=https://nebula.dev

# Localhost-only auth bypass (dev UX mode). When true, app auto-signs in with the profile below.
# DEV_LOCAL_AUTH=true
# DEV_LOCAL_GITHUB_UID=github-local-dev
# DEV_LOCAL_GITHUB_NAME=Your Name
# DEV_LOCAL_GITHUB_EMAIL=you@github.local
# DEV_LOCAL_GITHUB_AVATAR=https://avatars.githubusercontent.com/u/9919?v=4

# Optional: when the browser origin differs from the public site (e.g. tunneling), set for OAuth hint URLs in the client bundle
# VITE_PUBLIC_SITE_URL=https://your-service.onrender.com

# Main AI brain (chat, coding, orchestration). Provider is inferred from the key:
#   xai-…     → xAI / Grok (default model grok-4)
#   sk-ant-…  → Anthropic / Claude (default claude-3-5-sonnet-20241022)
# Optional override for any provider: MAIN_AI_CHAT_MODEL=
# Legacy alias: GROK_API_KEY_LUMEN
MAIN_AI_API_KEY=
# GROK_API_KEY_LUMEN=
# TEMPORARY: Claude 3.5 Sonnet fallback when Grok returns 402 / monthly quota (single request only; see lib/nebulaClaudeFallback.ts).
# CLAUDE_API_KEY=
# Optional: override xAI chat model id for main brain (default: grok-4).
# GROK_CHAT_MODEL_GROK41=grok-4

# Nebula Free-tier monthly token cap (not xAI/Anthropic provider quota):
# DISABLE_FREE_TIER_TOKEN_LIMIT=true   — force off
# ENFORCE_FREE_TIER_TOKEN_LIMIT=true   — force on (production billing)
# On Render, cap is off by default unless ENFORCE_FREE_TIER_TOKEN_LIMIT=true.

# Inspect (Quality Agent) only — `GROK_SWARM_API_KEY` + Grok 3-mini class; never used for `/api/grok/chat`.
GROK_SWARM_API_KEY=
# Optional xAI model for Inspect (default: grok-3-mini).
# GROK_SWARM_MODEL=grok-3-mini
# Legacy (unused in current lean Inspect path): reviewer model override.
# GROK_SWARM_REVIEWER_MODEL=grok-4

# Grok B — writer (Master Plan only; separate from brain)
GROK_3_API_KEY=
# Optional override (default: grok-4)
# GROK_B_MODEL=grok-4

# Stripe
STRIPE_SECRET_KEY=
PUBLIC_STRIPE_PUBLIC_KEY=

# --- Cloudflare R2 (S3-compatible) — all uploads / generated assets (see lib/nebulaR2Storage.ts) ---
# Dashboard: R2 → bucket → Settings → S3 API → Create API token (Object Read & Write).
# Preferred names (use these on Render). Short aliases also work: R2_ACCOUNT_ID, R2_ACCESS_KEY_ID,
# R2_SECRET_ACCESS_KEY, R2_BUCKET_NAME, R2_PUBLIC_URL.
# CLOUDFLARE_ACCOUNT_ID=          # Cloudflare dashboard → account ID (sidebar)
# CLOUDFLARE_ACCESS_KEY_ID=       # R2 S3 API access key id
# CLOUDFLARE_SECRET_ACCESS_KEY=   # R2 S3 API secret
# CLOUDFLARE_R2_BUCKET_NAME=      # Bucket name
# Optional public base URL (no trailing slash) for browser-accessible object URLs:
#   - R2 public bucket URL (https://pub-xxxx.r2.dev) or custom domain mapped to the bucket.
# Without CLOUDFLARE_R2_PUBLIC_URL (or R2_PUBLIC_URL), uploads succeed but responses omit `url`.
# CLOUDFLARE_R2_PUBLIC_URL=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ACCESS_KEY_ID=
CLOUDFLARE_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=
CLOUDFLARE_R2_PUBLIC_URL=

# v0 by Vercel — Nebula UI Studio first-pass UI generation (server env only; see lib/nebulaV0Resolver.ts)
V0_API_KEY=

# Nebula UI Studio → Pencil.dev mockups API (bundled client: lib/nebulaPencilDev.ts — no global CLI for users)
# Get a key from pencil.dev; server calls https://api.pencil.dev/v1/mockups/generate by default.
PENCIL_API_KEY=
# Optional aliases if your dashboard labels the secret differently:
# PENCIL_DEV_API_KEY=
# PENCIL_CLI_KEY=
# Optional override of the mockups endpoint:
# PENCIL_API_URL=https://api.pencil.dev/v1/mockups/generate
# Production without PENCIL_*: set to 1 to serve bundled demo SVG from lib/assets/ (no external API call).
# Local dev (NODE_ENV not production): demo mockups are used automatically when no key is set.
# NEBULA_UI_STUDIO_DEMO=1

# GROK TTS (new API)
GROK_TTS_NEW_API_KEY=

# Auth (server)
# --- GitHub “Sign in with GitHub” ---
# 1) GitHub → Settings → Developer settings → OAuth Apps → New OAuth App (or use an existing app).
# 2) Authorization callback URL in the GitHub OAuth App (must match redirect_uri exactly — origin + this path):
#    Production (nebula.dev):  https://nebula.dev/api/auth/github/callback
#    Render default host:      https://YOUR-SERVICE.onrender.com/api/auth/github/callback
#    Local dev:                http://localhost:3000/api/auth/github/callback   (same PORT as `npm run dev`; default 3000)
#    Set PUBLIC_SITE_URL to that same origin in production so the server builds the same redirect_uri.
# 3) Paste the app’s Client ID and generate a Client secret below. Both are required for login.
# 4) SESSION_SECRET: at least 16 random characters (cookie JWT signing).
# 5) DATABASE_URL: required so users can be stored (same DB as cloud sync).
# Local `npm run dev` uses the browser’s host for GitHub redirect_uri automatically (PUBLIC_SITE_URL is only forced in production).
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Optional: Resend for password-reset emails (otherwise dev logs the link; production should set both)
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=onboarding@resend.dev

# Nebula / Nebulla deploy architecture (internal; never expose IDs to the browser)
# Main Render account: nebulla.dev.ai@gmail.com | Public app domain family: nebulla.dev
#
# Per Nebula project, the server creates a Render **Project** via POST /v1/projects (Render does not expose POST /v1/workspaces).
# RENDER_API_KEY — Dashboard → Account → API Keys
# RENDER_OWNER_ID — Workspace Settings → ID (prefix tea- or usr-). Alias: RENDER_WORKSPACE_ID
# Without both, new users get synthetic `local-…` ids; on-disk folders are still isolated per project.
# RENDER_API_KEY=
# RENDER_OWNER_ID=

# Nebula Guardian — silent error memory (server). Hub: GET /api/guardian/hub?key=YOUR_SECRET
# GUARDIAN_HUB_SECRET=min-16-chars-random
# Optional: same value in Vite for silent browser error reports (never expose hub secret in the client bundle)
# GUARDIAN_REPORT_KEY=match-in-vite
# VITE_GUARDIAN_REPORT_KEY=match-in-vite
